    {
      "id": "node_1c_go_back_to_restaurant",
      "kind": "story",
      "title": "1C. GO BACK TO RESTAURANT",
      "position": {
        "x": 799.6666666666666,
        "y": 903.8333333333333
      },
      "phrases": [
        {
          "id": "phrase_001_you_gave_todd_a_se",
          "speaker": "Narrator",
          "text": "You gave Todd a second chance. That was the last thing you owed the version of yourself that fell in love with him two years ago.",
          "effects": [
            {
              "id": "effect_1c_go_back_to_restaurant",
              "key": "rain_choice",
              "operation": "set",
              "value": "returned_for_purse"
            }
          ],
          "choices": []
        },
        {
          "id": "phrase_002_this_version_of_yo",
          "speaker": "Narrator",
          "text": "This version of you deserves to get someplace warm.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_003_you_reach_for_your",
          "speaker": "Narrator",
          "text": "You reach for your phone.\nThen your purse.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_004_fuck_in_your_panic",
          "speaker": "Narrator",
          "text": "Fuck. In your panic, you must have-",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_005_the_restaurant_is_",
          "speaker": "Narrator",
          "text": "The restaurant is dark by the time you make it back.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_006_soaked_to_the_bone",
          "speaker": "Narrator",
          "text": "Soaked to the bone, you knock on the door with one last desperate hope that someone is still there. You really do not want to walk home through this mess.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_007_even_standing_stil",
          "speaker": "Narrator",
          "text": "Even standing still, your heart is pounding almost as hard as the rain drumming against the overhang.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_008_you_take_a_breath_",
          "speaker": "Narrator",
          "text": "You take a breath. Then another.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_009_you_wait_you_hope_",
          "speaker": "Narrator",
          "text": "You wait. You hope.\nThe entire evening has been a long wait, without reward.\nFuck.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_010_all_you_wanted_was",
          "speaker": "Narrator",
          "text": "All you wanted was warmth. To be seen. To be heard.\nTo be chosen.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_011_disconsolate_you_t",
          "speaker": "Narrator",
          "text": "Disconsolate, you turn to walk away-\nThe light turns on.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_012_holy_shit_are_you_",
          "speaker": "Michael",
          "text": "Holy shit... are you okay?\nCome inside and dry off in the kitchen, okay?\nIt's freezing out here. I was starting to wonder if something happened to you.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_013_yeah_i_was_just_wa",
          "speaker": "Diana",
          "text": "Yeah... I was just walking.\nI didn't realize I'd left my things behind until I went to call a ride.",
          "effects": [],
          "choices": [
            {
              "id": "choice_1c_go_back_to_restaurant_1",
              "text": "Get purse and call Uber",
              "targetNodeId": "node_4d_get_purse_and_call_uber",
              "conditions": []
            },
            {
              "id": "choice_1c_go_back_to_restaurant_2",
              "text": "Warm up in the kitchen",
              "targetNodeId": "node_1d_warm_up_in_kitchen_wet_kiss_in_kitchen",
              "conditions": []
            }
          ]
        }
      ]
    },
