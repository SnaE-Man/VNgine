    {
      "id": "node_1f_kitchen_sex_scene",
      "kind": "story",
      "title": "1F. KITCHEN SEX SCENE",
      "position": {
        "x": 1400.666666666667,
        "y": 901.1666666666667
      },
      "phrases": [
        {
          "id": "phrase_001_so_bring_young_wom",
          "speaker": "Diana",
          "text": "So... bring young women back here often?",
          "effects": [
            {
              "id": "effect_1f_kitchen_sex_scene",
              "key": "waiter_intimacy",
              "operation": "set",
              "value": "kitchen"
            }
          ],
          "choices": []
        },
        {
          "id": "phrase_002_he_chuckles_softly",
          "speaker": "Narrator",
          "text": "He chuckles softly at the thought, and you can't help but feel a kind of innocence behind it.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_003_you_got_me_this_wa",
          "speaker": "Michael",
          "text": "You got me. This was all part of my diabolical plan to make sure you didn't get hypothermia.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_004_truly_monstrous_ho",
          "speaker": "Diana",
          "text": "Truly monstrous.\nHow ever will your reputation recover?",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_005_i_hear_that_a_lot_",
          "speaker": "Michael",
          "text": "I hear that a lot. Not usually from the ladies, though. Mostly from my younger siblings when I twist their arms into picking up extra shifts.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_006_wait_you_run_this_",
          "speaker": "Diana",
          "text": "Wait... you run this place?",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_007_close_enough_that_",
          "speaker": "Michael",
          "text": "Close enough that I can get creative about how I define 'full service'.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_008_that_phrase_keeps_",
          "speaker": "Diana",
          "text": "That phrase keeps sounding dirtier every time you say it.",
          "effects": [],
          "choices": []
        },
        {
          "id": "phrase_009_that_s_on_you_i_wa",
          "speaker": "Michael",
          "text": "That's on you.\n*I* was talking about hospitality.",
          "effects": [],
